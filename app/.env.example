# Copy to .env.local (local dev) or .env.production (prod builds) and fill in.
# Vite exposes these to the client at build time — NEVER put server-only
# secrets here (no Anthropic/Stripe secret keys). Only publishable keys.

# --- Required ---------------------------------------------------------------

# Course API base URL, including the /api suffix.
#   Local: http://localhost:8001/api
#   Prod:  https://golfmaps-api.fly.dev/api
VITE_COURSE_API_URL=http://localhost:8001/api

# Shared secret sent as X-Scorecard-Auth. Must match SCORECARD_AUTH_SECRET on
# the course-api server. In a pure-JS client this value is embedded in the
# bundle and extractable — it is a soft gate, not real auth. Pair with:
#   - A hard spend cap on the Anthropic Console
#   - Fly-side per-IP rate limiting (already in the router)
VITE_SCORECARD_AUTH_SECRET=

# Supabase — auth + data. Anon key is safe to ship; RLS enforces access.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Optional integrations --------------------------------------------------

# Sentry client DSN for error tracking.
VITE_SENTRY_DSN=

# RevenueCat public API key for in-app subscriptions.
VITE_REVENUECAT_API_KEY=

# Stripe publishable key — for canvas print orders only.
VITE_STRIPE_PUBLISHABLE_KEY=

# PostHog for product analytics.
VITE_POSTHOG_KEY=
