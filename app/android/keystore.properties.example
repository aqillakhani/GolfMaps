# Copy to keystore.properties (gitignored) and fill in before running
#   ./gradlew bundleRelease
#
# Generate a keystore once per app with something like:
#   keytool -genkeypair -v \
#     -keystore app/release.keystore \
#     -alias golfmaps \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Keep the .keystore file and all four values below in a password manager.
# If you lose them, you will never be able to update this app on the
# Play Store under the same listing.
#
# Note: storeFile is resolved relative to the :app Gradle module, so the
# value below corresponds to the physical file at
#   android/app/release.keystore

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=golfmaps
keyPassword=CHANGE_ME
