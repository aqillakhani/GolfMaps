# Copy to .env and fill in for local development.
# In production these are set as Fly secrets (never committed).

# --- Required in production ------------------------------------------------

# Anthropic API key for the scorecard vision endpoint (Claude Haiku 4.5).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Shared secret the app must send as the X-Scorecard-Auth header. Generate a
# random 32+ character string (e.g. `openssl rand -hex 32`). Must match
# VITE_SCORECARD_AUTH_SECRET in the app's .env.
SCORECARD_AUTH_SECRET=

# Comma-separated list of origins allowed by CORS. In production, include the
# web domain plus Capacitor's scheme so native builds can reach the API.
# Example:
#   ALLOWED_ORIGINS=https://golfmaps.app,capacitor://localhost,http://localhost
ALLOWED_ORIGINS=

# --- Optional --------------------------------------------------------------

ENVIRONMENT=development     # or "production"
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
PORT=8001
